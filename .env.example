# Local Risk Alert Feed - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# OPTIONAL API KEYS
# These are only needed if you use the corresponding plugins
# =============================================================================

# Ticketmaster Discovery API (for PhoenixEventsPlugin)
# Get your key at: https://developer.ticketmaster.com/
# Free tier: 5,000 API calls per day
TICKETMASTER_API_KEY=

# EPA AirNow API (for AirNowPlugin)
# Get your key at: https://docs.airnowapi.org/account/request/
# Free, requires registration
AIRNOW_API_KEY=

# Georgia 511 / GDOT Developer API (for AtlantaTrafficPlugin)
# Get your key at: https://511ga.org/developers/doc
# Free, requires registration. Throttled to 10 calls / 60 seconds.
GEORGIA_511_API_KEY=

# New Jersey 511 / NJDOT Developer API (for NJTrafficPlugin — Jersey City)
# Get your key at: https://511nj.org/developers
# Free, requires registration. Same iBI511 events schema as 511NY.
NEW_JERSEY_511_API_KEY=

# TRANSCOM Data Exchange (for TRANSCOMPlugin — NY/NJ/CT incl. Port Authority/PATH)
# !!! NOT YET ENABLED — SCAFFOLD ONLY !!!
# Account creation is PAUSED May 1 – July 31, 2026 for FIFA World Cup 2026.
# Reopen registration on/after 2026-08-01 at https://data.xcmdata.org/
# (contact: techsonly@xcm.org). After approval, paste the registered event-feed
# URL below; the plugin will not run until TRANSCOM_FEED_URL is set.
TRANSCOM_FEED_URL=
TRANSCOM_API_KEY=

# =============================================================================
# NO API KEY REQUIRED
# These plugins use public data sources
# =============================================================================
# - NWSWeatherPlugin      (National Weather Service)
# - PhoenixFirePlugin     (Phoenix Fire Dept ArcGIS)
# - NIFCWildfirePlugin    (National Interagency Fire Center)
# - ArizonaTrafficPlugin  (Arizona DOT ArcGIS)
# - PhoenixConventionCenterPlugin (Ungerboeck public API)
# - AtlantaCrimePlugin    (Atlanta PD Open Data ArcGIS)
