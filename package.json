{
  "name": "@vigilisai/local-risk-alert-feed",
  "version": "1.1.0",
  "description": "TypeScript library for aggregating local risk alerts from multiple data sources via a plugin system",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./adapters/lambda": {
      "import": "./dist/esm/adapters/lambda.js",
      "require": "./dist/cjs/adapters/lambda.js",
      "types": "./dist/types/adapters/lambda.d.ts"
    },
    "./adapters/vercel": {
      "import": "./dist/esm/adapters/vercel.js",
      "require": "./dist/cjs/adapters/vercel.js",
      "types": "./dist/types/adapters/vercel.d.ts"
    },
    "./adapters/plugin-service": {
      "import": "./dist/esm/adapters/plugin-service.js",
      "require": "./dist/cjs/adapters/plugin-service.js",
      "types": "./dist/types/adapters/plugin-service.d.ts"
    },
    "./federation": {
      "import": "./dist/esm/federation/index.js",
      "require": "./dist/cjs/federation/index.js",
      "types": "./dist/types/federation/index.d.ts"
    },
    "./contract": {
      "import": "./dist/esm/contract/index.js",
      "require": "./dist/cjs/contract/index.js",
      "types": "./dist/types/contract/index.d.ts"
    },
    "./testing": {
      "import": "./dist/esm/testing/index.js",
      "require": "./dist/cjs/testing/index.js",
      "types": "./dist/types/testing/index.d.ts"
    },
    "./plugins/baseline": {
      "import": "./dist/esm/plugins/baseline/index.js",
      "require": "./dist/cjs/plugins/baseline/index.js",
      "types": "./dist/types/plugins/baseline/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "vigilis-plugin-verify": "./dist/cjs/cli/verify.js"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "alerts",
    "risk",
    "local",
    "gps",
    "weather",
    "crime",
    "events",
    "plugin"
  ],
  "author": "Vigilis AI",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/node": "^20.19.30",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  }
}
